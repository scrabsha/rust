+trait MessageOrTitle {
+    fn level(&self) -> &Level<'_>;
+    fn id(&self) -> Option<&Id<'_>>;
+    fn text(&self) -> &str;
+    fn allows_styling(&self) -> bool;
+}
+
+impl MessageOrTitle for Title<'_> {
+    fn level(&self) -> &Level<'_> {
+        &self.level
+    }
+    fn id(&self) -> Option<&Id<'_>> {
+        self.id.as_ref()
+    }
+    fn text(&self) -> &str {
+        self.text.as_ref()
+    }
+    fn allows_styling(&self) -> bool {
+        self.allows_styling
+    }
+}
